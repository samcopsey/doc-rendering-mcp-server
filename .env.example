# =============================================================================
# Doc Rendering MCP Server — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to source control.
# =============================================================================

# Azure Blob Storage (required for PDF/DOCX delivery)
AZURE_STORAGE_ACCOUNT_NAME=stcastdevdocs
AZURE_STORAGE_CONTAINER_NAME=documents

# Server
MCP_SERVER_PORT=3001
LOG_LEVEL=info
